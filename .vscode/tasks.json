{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Finance Tracker",
            "type": "shell",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-std=c++17",

                "src/main.cpp",
                "src/User.cpp",
                "src/UserManager.cpp",
                "src/Transaction.cpp",
                "src/FinanceManager.cpp",
                "src/FileManager.cpp",
                "src/InputValidator.cpp",
                "src/CategoryManager.cpp",
                "src/Budget.cpp",
                "src/Report.cpp",

                "-Iinclude",

                "-o",
                "FinanceTracker.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}